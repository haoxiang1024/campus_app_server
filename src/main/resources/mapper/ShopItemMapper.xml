<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.mapper.ShopItemMapper">

    <select id="selectAllActive" resultType="com.school.entity.ShopItem">
        SELECT * FROM shop_item WHERE status = 1 AND stock > 0 ORDER BY create_time DESC
    </select>

    <select id="selectByPrimaryKey" resultType="com.school.entity.ShopItem">
        SELECT * FROM shop_item WHERE id = #{id}
    </select>

    <update id="deductStock">
        UPDATE shop_item SET stock = stock - 1 WHERE id = #{id} AND stock > 0
    </update>
</mapper>