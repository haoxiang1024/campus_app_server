<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.mapper.LostFoundTypeMapper">


    <select id="GetAll" resultType="com.school.entity.LostFoundType">
        select id, name
        from lostfound_type
    </select>
    <select id="getAllType" resultType="java.lang.String">
        select name
        from lostfound_type
    </select>
    <select id="typeIdByName" resultType="java.lang.Integer">
        select id
        from school_app.lostfound_type
        where name = #{name}
    </select>
    <select id="selectTypeByPage" resultType="com.school.entity.LostFoundType">
        SELECT id, name
        FROM lostfoundtype
        <where>
            <if test="keyword != null and keyword != ''">
                name LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
        ORDER BY id ASC
    </select>

    <insert id="insertType" parameterType="com.school.entity.LostFoundType" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO lostfound_type (name) VALUES (#{name})
    </insert>

    <update id="updateType" parameterType="com.school.entity.LostFoundType">
        UPDATE lostfound_type
        SET name = #{name}
        WHERE id = #{id}
    </update>

    <delete id="deleteTypeById">
        DELETE FROM lostfound_type WHERE id = #{id}
    </delete>

    <delete id="deleteTypeBatch">
        DELETE FROM lostfoundtype WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>